# Copy to .env for local runs. docker-compose also reads this file.

# PostgreSQL
POSTGRES_USER=tickets
POSTGRES_PASSWORD=tickets
POSTGRES_DB=tickets

# Backend
DATABASE_URL=postgresql+psycopg://tickets:tickets@localhost:5432/tickets
FRONTEND_ORIGIN=http://localhost:3000
# Secret used to sign auth tokens — set a strong random value in production.
JWT_SECRET=dev-only-insecure-secret-change-in-prod

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
